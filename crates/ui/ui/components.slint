import { VerticalBox, HorizontalBox } from "std-widgets.slint";

export global TrivorTokens {
    in-out property <bool> is-light: false;

    // Ambient & chrome (theme-aware)
    in-out property <brush> bg-canvas: is-light
        ? @linear-gradient(155deg, #f8f8fc 0%, #f0f0f5 45%, #e8e8ef 100%)
        : @linear-gradient(155deg, #12121c 0%, #0c0c12 42%, #07070b 100%);
    in-out property <brush> glow-accent: is-light
        ? @radial-gradient(circle, #7c6cf028 0%, #7c6cf600 70%)
        : @radial-gradient(circle, #8b7cf650 0%, #8b7cf600 68%);
    in-out property <brush> glow-cool: is-light
        ? @radial-gradient(circle, #3b82f620 0%, #3b82f600 70%)
        : @radial-gradient(circle, #3b82f630 0%, #3b82f600 70%);

    // Glass surfaces (Slint gradients — readable without native vibrancy)
    in-out property <brush> glass-panel: is-light
        ? @linear-gradient(180deg, #ffffffee 0%, #ffffffd8 48%, #ffffffcc 100%)
        : @linear-gradient(180deg, #2a2a34 0%, #1e1e28 45%, #181822 100%);
    in-out property <brush> glass-panel-strong: is-light
        ? @linear-gradient(180deg, #fffffff8 0%, #ffffffe8 100%)
        : @linear-gradient(180deg, #32323e 0%, #242430 52%, #1c1c26 100%);
    in-out property <brush> glass-border: is-light
        ? @linear-gradient(180deg, #ffffff 0%, #00000018 100%)
        : @linear-gradient(180deg, #ffffff45 0%, #ffffff14 55%, #ffffff08 100%);
    in-out property <brush> glass-highlight: @linear-gradient(90deg, #ffffff00 0%, #ffffff50 50%, #ffffff00 100%);

    // Legacy solids (theme.rs still sets these)
    in-out property <brush> bg-base: #0c0c12;
    in-out property <brush> bg-elevated: #18181b;
    in-out property <brush> bg-surface: #1f1f23;
    in-out property <brush> bg-hover: #ffffff14;
    in-out property <brush> border: #ffffff1a;
    in-out property <brush> border-strong: #ffffff30;
    in-out property <brush> text-primary: #f4f4f5;
    in-out property <brush> text-muted: #8b8b96;
    in-out property <brush> accent: #8b7cf8;
    in-out property <brush> accent-hover: #a599ff;
    in-out property <brush> accent-soft: #8b7cf830;
    in-out property <brush> accent-gradient: is-light
        ? @linear-gradient(135deg, #8b7cf8 0%, #6d5ce6 100%)
        : @linear-gradient(135deg, #a78bfa 0%, #7c6cf0 45%, #5b5bd6 100%);
    in-out property <brush> viewport-bg: is-light
        ? @linear-gradient(180deg, #e8e8ef 0%, #dcdce4 100%)
        : @linear-gradient(180deg, #0a0a0f 0%, #050508 100%);
    in-out property <length> radius-md: 14px;
    in-out property <length> radius-sm: 10px;
    in-out property <length> sidebar-width: 280px;
    in-out property <length> panel-width: 320px;
}

export struct ModelListItem {
    title: string,
    subtitle: string,
    selected: bool,
}

export struct MaterialListItem {
    name: string,
    swatch: color,
}

/// Brand mark: transparent `logo.png` by default; `filled` uses light/dark background variants.
export component AppLogo inherits Rectangle {
    in property <length> size: 36px;
    in property <bool> filled: false;

    width: size;
    height: size;

    Image {
        width: 100%;
        height: 100%;
        source: root.filled
            ? (TrivorTokens.is-light
                ? @image-url("../assets/logo-light.png")
                : @image-url("../assets/logo-dark.png"))
            : @image-url("../assets/logo.png");
        image-fit: contain;
    }
}

export component AmbientBackground inherits Rectangle {
    width: 100%;
    height: 100%;
    background: TrivorTokens.bg-canvas;
    clip: true;

    Rectangle {
        width: 520px;
        height: 520px;
        x: -120px;
        y: -80px;
        border-radius: 260px;
        background: TrivorTokens.glow-accent;
    }
    Rectangle {
        width: 440px;
        height: 440px;
        x: parent.width - 280px;
        y: parent.height - 320px;
        border-radius: 220px;
        background: TrivorTokens.glow-cool;
    }
    Rectangle {
        width: 360px;
        height: 360px;
        x: parent.width * 0.38;
        y: parent.height * 0.22;
        border-radius: 180px;
        background: TrivorTokens.is-light
            ? @radial-gradient(circle, #a78bfa18 0%, #a78bfa00 72%)
            : @radial-gradient(circle, #a78bfa28 0%, #a78bfa00 70%);
    }

    @children
}

export component GlassSurface inherits Rectangle {
    in property <length> radius: TrivorTokens.radius-md;
    in property <bool> strong: false;

    border-radius: root.radius;
    background: root.strong ? TrivorTokens.glass-panel-strong : TrivorTokens.glass-panel;
    border-width: 1px;
    border-color: TrivorTokens.glass-border;
    clip: true;

    Rectangle {
        y: 0;
        height: 1px;
        width: 100%;
        background: TrivorTokens.glass-highlight;
    }

    Rectangle {
        y: parent.height - 48px;
        height: 48px;
        width: 100%;
        background: @linear-gradient(0deg, #00000018 0%, #00000000 100%);
    }

    content-layer := Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;
        @children
    }
}

export component TrivButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> ghost: false;
    callback clicked;

    min-width: primary ? 104px : 76px;
    height: 38px;
    border-radius: TrivorTokens.radius-sm;
    border-width: primary || ghost ? 0px : 1px;
    border-color: TrivorTokens.glass-border;
    background: primary
        ? (touch.pressed
            ? @linear-gradient(135deg, #b4a6ff 0%, #7c6cf0 100%)
            : (touch.has-hover
                ? @linear-gradient(135deg, #b9abff 0%, #8b7cf8 100%)
                : TrivorTokens.accent-gradient))
        : ghost
        ? (touch.has-hover ? TrivorTokens.bg-hover : transparent)
        : (touch.has-hover
            ? TrivorTokens.glass-panel-strong
            : TrivorTokens.glass-panel);

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: primary ? #ffffff : TrivorTokens.text-primary;
        font-size: 13px;
        font-weight: primary ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    animate background {
        duration: 200ms;
        easing: ease-out;
    }
}

export component SegmentedControl inherits Rectangle {
    in property <[string]> labels;
    in-out property <int> current: 0;
    callback selected(int);

    height: 38px;
    border-radius: TrivorTokens.radius-sm;
    background: TrivorTokens.glass-panel;
    border-width: 1px;
    border-color: TrivorTokens.border;

    HorizontalBox {
        padding: 4px;
        spacing: 4px;
        for label[idx] in root.labels: Rectangle {
            horizontal-stretch: 1;
            height: 100%;
            border-radius: 8px;
            background: root.current == idx
                ? TrivorTokens.accent-gradient
                : (seg-touch.has-hover ? TrivorTokens.bg-hover : transparent);

            seg-touch := TouchArea {
                width: 100%;
                height: 100%;
                clicked => {
                    root.current = idx;
                    root.selected(idx);
                }
            }

            Text {
                text: label;
                color: root.current == idx ? #ffffff : TrivorTokens.text-muted;
                font-size: 12px;
                font-weight: root.current == idx ? 600 : 400;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            animate background {
                duration: 220ms;
                easing: ease-out;
            }
        }
    }
}

export component ModelListRow inherits Rectangle {
    in property <ModelListItem> entry;
    callback activate;

    height: 64px;
    border-radius: TrivorTokens.radius-sm;
    background: entry.selected
        ? @linear-gradient(90deg, #8b7cf838 0%, #8b7cf812 55%, #ffffff06 100%)
        : (row-touch.has-hover ? TrivorTokens.glass-panel : transparent);
    border-width: entry.selected ? 1px : 0px;
    border-color: TrivorTokens.glass-border;

    Rectangle {
        width: 3px;
        height: parent.height - 14px;
        y: 7px;
        border-radius: 2px;
        background: entry.selected
            ? TrivorTokens.accent-gradient
            : transparent;
        animate background {
            duration: 220ms;
            easing: ease-out;
        }
    }

    row-touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.activate(); }
    }

    HorizontalBox {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;

        AppLogo {
            size: 42px;
        }

        VerticalBox {
            spacing: 3px;
            Text {
                text: entry.title;
                color: TrivorTokens.text-primary;
                font-size: 13px;
                font-weight: entry.selected ? 600 : 500;
                overflow: elide;
            }
            Text {
                text: entry.subtitle;
                color: TrivorTokens.text-muted;
                font-size: 11px;
                overflow: elide;
            }
        }
    }

    animate background {
        duration: 180ms;
        easing: ease-out;
    }
}

export component MaterialRow inherits Rectangle {
    in property <MaterialListItem> item;
    height: 32px;

    HorizontalBox {
        spacing: 10px;
        Rectangle {
            width: 22px;
            height: 22px;
            border-radius: 6px;
            background: item.swatch;
            border-width: 1px;
            border-color: TrivorTokens.border-strong;
        }
        Text {
            text: item.name;
            color: TrivorTokens.text-primary;
            font-size: 12px;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }
}

export component MetricRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 28px;

    HorizontalBox {
        Text {
            text: root.label;
            color: TrivorTokens.text-muted;
            font-size: 12px;
            horizontal-stretch: 1;
        }
        Text {
            text: root.value;
            color: TrivorTokens.text-primary;
            font-size: 12px;
            font-weight: 500;
        }
    }
}

export component Spinner inherits Rectangle {
    width: 52px;
    height: 52px;
    property <float> pulse: 0.35;

    border-width: 3px;
    border-radius: 26px;
    border-color: TrivorTokens.accent;
    background: transparent;
    opacity: 0.3 + 0.7 * pulse;

    spin-timer := Timer {
        interval: 16ms;
        running: true;
        triggered => { root.pulse = mod(root.pulse + 0.035, 1.0); }
    }
}

export component LoadingOverlay inherits Rectangle {
    in property <string> status-text;
    in property <int> percent;

    width: 100%;
    height: 100%;
    background: @linear-gradient(180deg, #00000055 0%, #00000088 100%);

    GlassSurface {
        width: 300px;
        height: 220px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        radius: TrivorTokens.radius-md;
        strong: true;

        VerticalBox {
            padding: 28px;
            spacing: 18px;

            Spinner { }

            Text {
                text: root.status-text;
                color: TrivorTokens.text-muted;
                font-size: 13px;
                horizontal-alignment: center;
            }

            Rectangle {
                width: 100%;
                height: 5px;
                border-radius: 3px;
                background: #ffffff14;
                Rectangle {
                    width: parent.width * (root.percent / 100);
                    height: 100%;
                    border-radius: 3px;
                    background: TrivorTokens.accent-gradient;
                    animate width {
                        duration: 260ms;
                        easing: ease-out;
                    }
                }
            }

            Text {
                text: "\{root.percent}%";
                color: TrivorTokens.text-primary;
                font-size: 28px;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }
    }
}

export component SettingsSheet inherits Rectangle {
    in property <bool> open;
    in property <string> title;
    in property <string> language-label;
    in property <string> appearance-label;
    in property <[string]> locale-labels;
    in property <[string]> theme-labels;
    in-out property <int> locale-index;
    in-out property <int> theme-index;
    callback close-panel;
    callback locale-changed(int);
    callback theme-changed(int);

    width: 380px;
    opacity: open ? 1 : 0;
    y: open ? 64px : 48px;
    visible: root.opacity > 0.01;
    z: 320;

    GlassSurface {
        width: 100%;
        height: 100%;
        radius: TrivorTokens.radius-md;
        strong: true;

        VerticalBox {
        padding: 24px;
        spacing: 20px;

        HorizontalBox {
            Text {
                text: root.title;
                color: TrivorTokens.text-primary;
                font-size: 18px;
                font-weight: 600;
                horizontal-stretch: 1;
            }
            close-ta := TouchArea {
                width: 34px;
                height: 34px;
                clicked => { root.close-panel(); }
                Rectangle {
                    border-radius: 9px;
                    background: close-ta.has-hover ? TrivorTokens.bg-hover : transparent;
                    Text {
                        text: "✕";
                        color: TrivorTokens.text-muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Text {
            text: root.language-label;
            color: TrivorTokens.text-muted;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.6px;
        }
        SegmentedControl {
            labels: root.locale-labels;
            current: root.locale-index;
            selected(idx) => {
                root.locale-index = idx;
                root.locale-changed(idx);
            }
        }

        Text {
            text: root.appearance-label;
            color: TrivorTokens.text-muted;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.6px;
        }
        SegmentedControl {
            labels: root.theme-labels;
            current: root.theme-index;
            selected(idx) => {
                root.theme-index = idx;
                root.theme-changed(idx);
            }
        }
        }
    }

    animate opacity {
        duration: 300ms;
        easing: ease-in-out;
    }
    animate y {
        duration: 340ms;
        easing: ease-out;
    }
}

export component SettingsBackdrop inherits Rectangle {
    in property <bool> open;
    in property <string> title;
    in property <string> language-label;
    in property <string> appearance-label;
    in property <[string]> locale-labels;
    in property <[string]> theme-labels;
    in-out property <int> locale-index;
    in-out property <int> theme-index;
    callback close-panel;
    callback locale-changed(int);
    callback theme-changed(int);

    width: 100%;
    height: 100%;
    background: @linear-gradient(180deg, #00000044 0%, #00000099 100%);
    opacity: open ? 1 : 0;
    visible: root.opacity > 0.01;
    z: 280;

    animate opacity {
        duration: 280ms;
        easing: ease-in-out;
    }

    backdrop-ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled: open;
        clicked => { root.close-panel(); }
    }

    SettingsSheet {
        x: parent.width - self.width - 20px;
        open: root.open;
        title: root.title;
        language-label: root.language-label;
        appearance-label: root.appearance-label;
        locale-labels: root.locale-labels;
        theme-labels: root.theme-labels;
        locale-index: root.locale-index;
        theme-index: root.theme-index;
        close-panel => { root.close-panel(); }
        locale-changed(idx) => { root.locale-changed(idx); }
        theme-changed(idx) => { root.theme-changed(idx); }
    }
}
