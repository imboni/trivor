import { LineEdit, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";
import {
    TrivorTokens,
    AmbientBackground,
    AppLogo,
    GlassSurface,
    ModelListItem,
    MaterialListItem,
    TrivButton,
    ModelListRow,
    MaterialRow,
    MetricRow,
    LoadingOverlay,
    SettingsBackdrop,
} from "components.slint";

export { TrivorTokens }

export component MainWindow inherits Window {
    title: root.window-title;
    default-font-family: ".AppleSystemUIFont";
    default-font-size: 13px;
    background: TrivorTokens.bg-canvas;
    preferred-width: 1280px;
    preferred-height: 840px;
    min-width: 1024px;
    min-height: 680px;

    in-out property <string> window-title: "Trivor";
    in-out property <string> app-name: "Trivor";
    in-out property <string> tagline: "";
    in-out property <string> open-label: "Open…";
    in-out property <string> settings-label: "Settings";
    in-out property <string> search-placeholder: "";
    in-out property <string> sidebar-title: "Models";
    in-out property <string> sidebar-empty: "";
    in-out property <string> panel-model-title: "Model";
    in-out property <string> panel-dimensions-title: "Dimensions";
    in-out property <string> panel-materials-title: "Materials";
    in-out property <string> empty-title: "";
    in-out property <string> empty-subtitle: "";
    in-out property <string> metric-format-label: "Format";
    in-out property <string> metric-size-label: "Size";
    in-out property <string> metric-meshes-label: "Meshes";
    in-out property <string> metric-materials-label: "Materials";
    in-out property <string> metric-vertices-label: "Vertices";
    in-out property <string> metric-triangles-label: "Triangles";
    in-out property <string> settings-title: "Settings";
    in-out property <string> language-label: "Language";
    in-out property <string> appearance-label: "Appearance";
    in-out property <[string]> locale-segment-labels: ["English", "简体中文", "System"];
    in-out property <[string]> theme-segment-labels: ["Dark", "Light", "System"];
    in-out property <int> locale-index: 0;
    in-out property <int> theme-index: 0;
    in-out property <bool> settings-open: false;
    in-out property <bool> show-empty: true;
    in-out property <bool> show-loading: false;
    in-out property <bool> show-viewport: false;
    in-out property <bool> inspector-visible: false;
    in-out property <int> loading-percent: 0;
    in-out property <image> viewport-image;
    in-out property <string> status-text: "";
    in-out property <[ModelListItem]> model-list;
    in-out property <[MaterialListItem]> material-list;
    in-out property <string> metric-format-value: "—";
    in-out property <string> metric-size-value: "—";
    in-out property <string> metric-meshes-value: "—";
    in-out property <string> metric-materials-value: "—";
    in-out property <string> metric-vertices-value: "—";
    in-out property <string> metric-triangles-value: "—";
    in-out property <string> metric-dim-w: "—";
    in-out property <string> metric-dim-h: "—";
    in-out property <string> metric-dim-d: "—";

    callback open-file;
    callback locale-changed(int);
    callback theme-changed(int);
    callback model-selected(int);
    callback frame-tick();

    render-timer := Timer {
        interval: 33ms;
        running: true;
        triggered => { root.frame-tick(); }
    }

    AmbientBackground {
        width: 100%;
        height: 100%;

        VerticalBox {
            // Top chrome — glass bar
            GlassSurface {
                height: 58px;
                radius: 0px;
                strong: true;

                HorizontalBox {
                    padding-left: 22px;
                    padding-right: 22px;
                    spacing: 14px;

                    AppLogo {
                        size: 36px;
                    }

                    VerticalBox {
                        spacing: 2px;
                        Text {
                            text: root.app-name;
                            color: TrivorTokens.text-primary;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        Text {
                            text: root.tagline;
                            color: TrivorTokens.text-muted;
                            font-size: 11px;
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }

                    TrivButton {
                        label: root.open-label;
                        primary: true;
                        clicked => { root.open-file(); }
                    }

                    TrivButton {
                        label: root.settings-label;
                        ghost: true;
                        clicked => { root.settings-open = true; }
                    }
                }
            }

            HorizontalBox {
                vertical-stretch: 1;

                // Sidebar
                GlassSurface {
                    width: TrivorTokens.sidebar-width;
                    radius: 0px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 14px;

                        Text {
                            text: root.sidebar-title;
                            color: TrivorTokens.text-muted;
                            font-size: 11px;
                            font-weight: 600;
                            letter-spacing: 1px;
                        }

                        search := LineEdit {
                            placeholder-text: root.search-placeholder;
                            enabled: false;
                        }

                        if root.model-list.length == 0: VerticalBox {
                            vertical-stretch: 1;
                            padding-top: 40px;
                            Text {
                                text: root.sidebar-empty;
                                color: TrivorTokens.text-muted;
                                font-size: 12px;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }
                        }

                        if root.model-list.length > 0: ScrollView {
                            vertical-stretch: 1;
                            VerticalBox {
                                spacing: 6px;
                                for entry[idx] in root.model-list: ModelListRow {
                                    entry: entry;
                                    activate => { root.model-selected(idx); }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    background: TrivorTokens.glass-border;
                }

                // Viewport — transparent so the model-viewer WebView shows through.
                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;
                    clip: false;

                    if !root.show-viewport: Rectangle {
                        width: 100%;
                        height: 100%;
                        background: TrivorTokens.viewport-bg;
                    }

                    // 3D preview: Google model-viewer in a native WebView overlay.

                    if root.show-empty && !root.show-loading: GlassSurface {
                        width: 420px;
                        height: 280px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        strong: true;

                        VerticalBox {
                            padding: 36px;
                            spacing: 14px;
                            alignment: center;
                            AppLogo {
                                size: 80px;
                            }
                            Text {
                                text: root.empty-title;
                                color: TrivorTokens.text-primary;
                                font-size: 24px;
                                font-weight: 500;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: root.empty-subtitle;
                                color: TrivorTokens.text-muted;
                                font-size: 14px;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                            Rectangle { height: 8px; }
                            TrivButton {
                                label: root.open-label;
                                primary: true;
                                clicked => { root.open-file(); }
                            }
                        }
                    }

                    if root.show-loading: LoadingOverlay {
                        width: 100%;
                        height: 100%;
                        status-text: root.status-text;
                        percent: root.loading-percent;
                    }
                }

                Rectangle {
                    width: 1px;
                    background: TrivorTokens.glass-border;
                }

                // Inspector
                GlassSurface {
                    width: TrivorTokens.panel-width;
                    radius: 0px;

                    ScrollView {
                        VerticalBox {
                            padding: 18px;
                            spacing: 14px;
                            opacity: root.inspector-visible ? 1 : 0.35;
                            animate opacity {
                                duration: 400ms;
                                easing: ease-out;
                            }

                            Text {
                                text: root.panel-model-title;
                                color: TrivorTokens.text-primary;
                                font-size: 16px;
                                font-weight: 600;
                            }

                            GlassSurface {
                                radius: TrivorTokens.radius-sm;
                                VerticalBox {
                                    padding: 14px;
                                    spacing: 6px;
                                    Text {
                                        text: "Overview";
                                        color: TrivorTokens.text-muted;
                                        font-size: 11px;
                                        font-weight: 600;
                                        letter-spacing: 0.5px;
                                    }
                                    MetricRow { label: root.metric-format-label; value: root.metric-format-value; }
                                    MetricRow { label: root.metric-size-label; value: root.metric-size-value; }
                                    MetricRow { label: root.metric-meshes-label; value: root.metric-meshes-value; }
                                    MetricRow { label: root.metric-materials-label; value: root.metric-materials-value; }
                                    MetricRow { label: root.metric-vertices-label; value: root.metric-vertices-value; }
                                    MetricRow { label: root.metric-triangles-label; value: root.metric-triangles-value; }
                                }
                            }

                            GlassSurface {
                                radius: TrivorTokens.radius-sm;
                                VerticalBox {
                                    padding: 14px;
                                    spacing: 6px;
                                    Text {
                                        text: root.panel-dimensions-title;
                                        color: TrivorTokens.text-muted;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    MetricRow { label: "W"; value: root.metric-dim-w; }
                                    MetricRow { label: "H"; value: root.metric-dim-h; }
                                    MetricRow { label: "D"; value: root.metric-dim-d; }
                                }
                            }

                            if root.material-list.length > 0: GlassSurface {
                                radius: TrivorTokens.radius-sm;
                                VerticalBox {
                                    padding: 14px;
                                    spacing: 6px;
                                    Text {
                                        text: root.panel-materials-title;
                                        color: TrivorTokens.text-muted;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    for mat[i] in root.material-list: MaterialRow {
                                        item: mat;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if root.settings-open: settings-layer := SettingsBackdrop {
        width: 100%;
        height: 100%;
        open: root.settings-open;
        title: root.settings-title;
        language-label: root.language-label;
        appearance-label: root.appearance-label;
        locale-labels: root.locale-segment-labels;
        theme-labels: root.theme-segment-labels;
        locale-index: root.locale-index;
        theme-index: root.theme-index;
        close-panel => { root.settings-open = false; }
        locale-changed(idx) => { root.locale-changed(idx); }
        theme-changed(idx) => { root.theme-changed(idx); }
    }
}
